{
  "name": "catan-map-generator",
  "private": true,
  "version": "1.0.0",
  "description": "Constraint-driven Catan map generator with balanced, fair, and challenge-mode boards. Shareable URLs, responsive mobile UI, snake-draft fairness scoring.",
  "type": "module",
  "homepage": "https://nathantbenke.github.io/catan-map-generator/",
  "repository": {
    "type": "git",
    "url": "https://github.com/nathantbenke/catan-map-generator.git"
  },
  "author": "Nathan Thomas-Benke",
  "license": "MIT",
  "keywords": [
    "catan",
    "board-game",
    "map-generator",
    "react",
    "typescript",
    "constraint-satisfaction"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:og": "node scripts/build-og.mjs"
  },
  "dependencies": {
    "@use-gesture/react": "^10.3.1",
    "pako": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/pako": "^2.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
